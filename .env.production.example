# ── BidAgent V2 Production Environment ─────────────────
# Copy this to .env on the production server and fill in real values.
# NEVER commit .env to git.

# ── Application ───────────────────────────────────────
APP_ENV=production
DEBUG=false
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
APP_NAME=BidAgent V2
APP_VERSION=2.0.0

# ── Database (Docker internal network — hostname is container name) ──
DATABASE_URL=postgresql+asyncpg://bidagent:REPLACE_STRONG_DB_PASSWORD@postgres:5432/bidagent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Used by docker-compose to create the PG container
POSTGRES_USER=bidagent
POSTGRES_PASSWORD=REPLACE_STRONG_DB_PASSWORD
POSTGRES_DB=bidagent

# ── Redis (Docker internal network) ──────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM (DeepSeek) ───────────────────────────────────
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-reasoner
LLM_MAX_RETRIES=3
LLM_TIMEOUT=120

# ── Embedding ─────────────────────────────────────────
EMBEDDING_PROVIDER=hunyuan
EMBEDDING_DIMENSION=1024
EMBEDDING_FALLBACK_ENABLED=true
HUNYUAN_SECRET_ID=xxx
HUNYUAN_SECRET_KEY=xxx
ZHIPU_API_KEY=xxx

# ── Celery (Docker internal network — redis DB 1 & 2) ─
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_URL=redis://redis:6379/2

# ── Crawler ───────────────────────────────────────────
CRAWLER_REQUEST_DELAY=2.0

# ── Upload ────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=https://bid.easudata.com

# ── Frontend (baked into Docker image at build time) ──
# NEXT_PUBLIC_API_URL is set via --build-arg in CI, not here.
