# ── Application ───────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bidagent:bidagent@localhost:5432/bidagent
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=change-me-also-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM (DeepSeek) ───────────────────────────────────
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-reasoner
LLM_MAX_RETRIES=3
LLM_TIMEOUT=120

# ── Embedding ─────────────────────────────────────────
EMBEDDING_PROVIDER=hunyuan
EMBEDDING_DIMENSION=1024
EMBEDDING_FALLBACK_ENABLED=true
HUNYUAN_SECRET_ID=xxx
HUNYUAN_SECRET_KEY=xxx
ZHIPU_API_KEY=xxx

# ── Celery ────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_URL=redis://localhost:6379/2

# ── Crawler ───────────────────────────────────────────
CRAWLER_REQUEST_DELAY=2.0

# ── Upload ────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
